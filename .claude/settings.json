{
  "permissions": {
    "allow": [
      "Bash(git -C * status)",
      "Bash(git add *)",
      "Bash(npm run *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Write(tests/**)",
      "WebFetch(domain:*.npmjs.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:registry.npmjs.org)"
    ],
    "deny": [
      "Read(**/secrets/**)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Edit(**/.env*)",
      "Write(**/.env*)",
      "Bash(rm *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git pull --rebase *)",
      "Bash(git push --force *)",
      "Bash(npm publish *)",
      "Bash(docker push *)",
      "Edit(package.json)",
      "Edit(README.md)"
    ],
    "defaultMode": "default"
  }
}
