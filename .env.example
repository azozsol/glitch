# --- Google Sheets (service account, Sheets API v4) ---
# Save each contact-form submission as a row in a shared Google Sheet.
# Create a Google Cloud service account with the Sheets API enabled, then
# share the target spreadsheet with its client_email as an Editor.
GOOGLE_SERVICE_ACCOUNT_EMAIL=my-service-account@my-project.iam.gserviceaccount.com
# Paste the PEM private key from the service account JSON key, with literal
# \n for newlines so it fits on a single env var line.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=1AbCDefGhIJkLmNoPQRstuVWxyz1234567890
# Optional -- sheet/tab name to append rows to. Defaults to "Submissions".
GOOGLE_SHEETS_SHEET_NAME=Submissions

# --- Resend (contact form emails) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Must be a verified sender on a domain you own in Resend.
RESEND_FROM_EMAIL="GLITCH.BE <contact@glitch.be>"
# Comma-separated list of internal recipients for lead notifications.
CONTACT_NOTIFICATION_EMAIL=leads@glitch.be



#glitchbrussels.com